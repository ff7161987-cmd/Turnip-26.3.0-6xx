                      struct tu_renderpass_result **autotune_result)
 {
+    // Força o uso de sysmem rendering para máxima compatibilidade
+    // e performance em GPUs Mali e Adreno.
+    // Atenção: garante que GMEM não será usado, evitando problemas de overflow.
+    cmd->state.rp.gmem_disable_reason = "Forced sysmem for full compatibility";
